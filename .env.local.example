# ============================================================
# Configuration SkillHunt
# Copiez ce fichier en .env.local et remplissez vos credentials
# ============================================================

# Supabase - Obligatoire (auth + historique)
# Créez un projet sur https://supabase.com et copiez les valeurs depuis
# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# France Travail (Pôle Emploi) - Recommandé, API officielle gratuite
# Inscription sur : https://francetravail.io/data/api/offres-emploi
# 1. Créez un compte sur francetravail.io
# 2. Créez une application et obtenez vos identifiants OAuth2
# 3. Scope requis : api_offresdemploiv2 o2dsoffre
FRANCE_TRAVAIL_CLIENT_ID=your_client_id_here
FRANCE_TRAVAIL_CLIENT_SECRET=your_client_secret_here

# APEC - API partenaire (accès sur demande)
# Voir : https://www.apec.fr/partenaires/api-apec.html
# Sans cette clé, APEC ne sera pas disponible (SPA Angular protégée)
APEC_API_KEY=your_apec_api_key_here

# Jobteaser - API partenaire (accès sur demande)
# Voir : https://www.jobteaser.com/fr/entreprises/api
# Sans ce token, Jobteaser ne sera pas disponible (SPA React protégée)
JOBTEASER_API_TOKEN=your_jobteaser_token_here

# Welcome to the Jungle - Aucune config nécessaire (Algolia public)
# Indeed - Aucune config nécessaire (scraping HTML)
# Note: Indeed peut être bloqué par Cloudflare depuis certains serveurs
